// This is your Prisma schema file

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}


// --- Enums ---
enum Role {
  OWNER
  ADMIN
  MEMBER
}

enum ProjectStatus {
  PENDING
  ACTIVE
  COMPLETED
}

enum TaskStatus {
  IN_PROGRESS
  TODO
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

// --- Models ---

model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  password     String
  refreshToken String?
  isVerified   Boolean  @default(false)
  status       String        @default("ACTIVE")
  createdAt    DateTime      @default(now())
  profile        Profile?
  
  workspaceUsers WorkspaceUser[]
  projects       Project[]     @relation("CreatedProjects")
  projectUsers   ProjectUser[]
  notifications  Notification[]
  userNotis      UserNoti[]
  activityLogs   ActivityLog[]
  invitations    Invitation[]  @relation("InvitedBy")
  invitedTo      Invitation[]  @relation("InvitedTo")
}

model Profile {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String?
  avatar    String?
  jobTitle  String?
  bio       String?
  userId    Int      @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId Int?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])
 
}

model Workspace {
  id            Int          @id @default(autoincrement())
  name          String
  logo          String?
  ownerId       Int?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  profile       Profile[]
  workspaceUsers WorkspaceUser[]
  projects       Project[]
  tasks          Task[]
  invitations    Invitation[]
  notifications  Notification[]
  projectUsers   ProjectUser[]
}

model Invitation {
  id          Int              @id @default(autoincrement())
  workspaceId Int
  email       String
  role        Role             @default(MEMBER)
  status      InvitationStatus @default(PENDING)
  invitedBy   Int
  invitedTo   Int?
  createdAt   DateTime         @default(now())
  workspace   Workspace        @relation(fields: [workspaceId], references: [id],onDelete: Cascade)
  sender      User             @relation("InvitedBy", fields: [invitedBy], references: [id])
  receiver    User?            @relation("InvitedTo", fields: [invitedTo], references: [id])
}

model WorkspaceUser {
  id          Int       @id @default(autoincrement())
  workspaceId Int
  userId      Int
  role         Role          @default(MEMBER)
  workspace   Workspace @relation(fields: [workspaceId], references: [id],onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id])
  @@unique([userId, workspaceId])
}

model Project {
  id          Int           @id @default(autoincrement())
  workspaceId Int
  createBy    Int
  name        String
  description String?
  status      ProjectStatus @default(PENDING)
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime      @default(now())
  workspace    Workspace     @relation(fields: [workspaceId], references: [id],onDelete: Cascade)
  creator      User          @relation("CreatedProjects", fields: [createBy], references: [id])
  projectUsers ProjectUser[]
  tasks        Task[]
}

model ProjectUser {
  id        Int     @id @default(autoincrement())
  projectId Int
  addedById Int
  userId    Int 
  role      Role    @default(MEMBER)
  workspaceId Int
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([projectId])
}

model Task {
  id          Int        @id @default(autoincrement())
  workspaceId Int
  projectId   Int
  title       String
  description String?
  priority    Priority   @default(MEDIUM)
  status      TaskStatus @default(IN_PROGRESS)
  dueDate     DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  comments    Comment[]
  taskUsers   TaskUser[] 
}

model TaskUser {
  id          Int      @id @default(autoincrement())
  workspaceId Int
  projectId   Int
  userId      Int
  taskId      Int
  role        Role     @default(MEMBER)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([userId, taskId]) 
}

model Comment {
  id          Int      @id @default(autoincrement())
  workspaceId Int
  taskId      Int
  authorId    Int
  content     String
  createdAt   DateTime @default(now())
  task        Task     @relation(fields: [taskId], references: [id])
}

model Notification {
  id          Int       @id @default(autoincrement())
  workspaceId Int
  userId      Int
  message     String
  isRead      Boolean   @default(false)
  createdAt   DateTime  @default(now())
  workspace Workspace    @relation(fields: [workspaceId], references: [id],onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id])
  userNotis UserNoti[]
}

model UserNoti{
  id             Int          @id @default(autoincrement())
  userId         Int
  notificationId Int
  isRead          Boolean      @default(false)
  user           User         @relation(fields: [userId], references: [id])
  notification   Notification @relation(fields: [notificationId], references: [id],onDelete: Cascade)
}

model ActivityLog {
  id          Int       @id @default(autoincrement())
  userId      Int
  action      String
  entityType  String
  entityId    Int
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id])
}
